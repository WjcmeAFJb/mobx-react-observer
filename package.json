{
  "name": "mobx-react-observer",
  "version": "1.5.0",
  "description": "Automatic React observer for Mobx",
  "files": [
    "dist",
    "wasm",
    "swc"
  ],
  "module": "./dist/esm/index.js",
  "main": "./dist/esm/index.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "types": "./dist/esm/index.d.ts",
      "require": "./dist/cjs/index.cjs"
    },
    "./babel-plugin": {
      "import": "./dist/esm/babel-plugin.js",
      "types": "./dist/esm/babel-plugin.d.ts",
      "require": "./dist/cjs/babel-plugin.cjs"
    },
    "./swc-plugin": {
      "import": "./dist/esm/swc-plugin.js",
      "types": "./dist/esm/swc-plugin.d.ts",
      "require": "./dist/cjs/swc-plugin.cjs"
    },
    "./wasm/observer.wasm": "./wasm/observer.wasm"
  },
  "types": "./dist/esm/index.d.ts",
  "scripts": {
    "build": "npm run clean && npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p ./tsconfig.build-cjs.json && node renameToCjs.js",
    "build:esm": "tsc -p ./tsconfig.build-esm.json",
    "clean": "rimraf ./dist",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "mobx",
    "observer"
  ],
  "author": "Christian Alfoni (forked)",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.26.8",
    "@babel/plugin-syntax-jsx": "^7.24.7",
    "@babel/plugin-syntax-typescript": "^7.24.7",
    "@babel/preset-typescript": "^7.26.0",
    "@swc/core": "^1.15.30",
    "@types/babel__core": "^7.20.5",
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^22.13.17",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "@babel/types": "^7.26.8",
    "minimatch": "^10.0.1",
    "mobx-react-lite": "^4.1.0"
  },
  "peerDependencies": {
    "@babel/core": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@babel/core": {
      "optional": true
    }
  }
}
